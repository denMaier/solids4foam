SOLIDS4FOAM_ROOT := ../..

sinclude $(SOLIDS4FOAM_ROOT)/etc/wmake-options
sinclude $(SOLIDS4FOAM_ROOT)/../etc/wmake-options

VERSION_SPECIFIC_INC += \
    -DS4F_NO_USE_EIGEN \
    -DS4F_NO_USE_PETSC

EXE_INC = \
    -Wno-old-style-cast -Wno-deprecated-declarations \
    $(VERSION_SPECIFIC_INC) \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/finiteArea/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/dynamicMesh/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/dynamicFvMesh/lnInclude \
    -I$(LIB_SRC)/dynamicMesh/topoChangerFvMesh/lnInclude \
    -I$(LIB_SRC)/dynamicFvMesh/lnInclude \
    -I$(LIB_SRC)/fvMotionSolver/lnInclude \
    -I$(LIB_SRC)/surfMesh/lnInclude \
    -I$(LIB_SRC)/tetFiniteElement/lnInclude

LIB_LIBS = \
    -lfiniteVolume \
    -lfiniteArea \
    -ldynamicFvMesh \
    -ldynamicMesh \
    -ltopoChangerFvMesh \
    -lfvMotionSolvers \
    -lmeshTools \
    -L$(FOAM_MODULE_LIBBIN) \
