#!/bin/bash
cd "${0%/*}" || exit  # Run from this directory

echo; echo "Checking ThirdParty"

# Eigen library: http://eigen.tuxfamily.org
# Optionally, you can set the Eigen installation location, e.g.
#     export EIGEN_DIR="/opt/local/include/eigen3"
# If you would not like eigen to be used, set the S4F_NO_USE_EIGEN variable, i.e.
#    export S4F_NO_USE_EIGEN=1

echo "Checking eigen"
if [[ -n ${S4F_NO_USE_EIGEN:-} ]]; then
    echo "The S4F_NO_USE_EIGEN variable is set so Eigen will not be used"
elif [[ -d "$(pwd)/eigen3" ]]; then
    echo "eigen3 found"
else
    if [[ -z ${EIGEN_DIR:-} ]]; then
        # Look for a system install and stop at the first match
        EIGEN_SIG_FILE=$(find /usr/include /opt -type f -name signature_of_eigen3_matrix_library 2>/dev/null -print -quit)

        if [[ -n "$EIGEN_SIG_FILE" ]]; then
            EIGEN_DIR="$(dirname "$EIGEN_SIG_FILE")"
            echo "Linking \"$EIGEN_DIR\" to eigen3"
            if [[ -e eigen3 && ! -L eigen3 ]]; then
                echo "Refusing to overwrite existing non-symlink 'eigen3'"; exit 1
            fi
            ln -sfn "$EIGEN_DIR" eigen3
        else
            # Download Eigen
            echo "Downloading Eigen 3.3.7"
            URL="https://gitlab.com/libeigen/eigen/-/archive/3.3.7/eigen-3.3.7.tar.gz"
            if command -v curl >/dev/null 2>&1; then
                curl -L "$URL" -o eigen-3.3.7.tar.gz || { echo "Download failed!"; exit 1; }
            else
                wget --no-check-certificate "$URL" || { echo "Download failed!"; exit 1; }
            fi
            tar xvf eigen-3.3.7.tar.gz >/dev/null
            rm -f eigen-3.3.7.tar.gz
            mv eigen-3.3.7 eigen3
        fi
    else
        echo "EIGEN_DIR is set: creating symbolic link"
        if [[ -e eigen3 && ! -L eigen3 ]]; then
            echo "Refusing to overwrite existing non-symlink 'eigen3'"; exit 1
        fi
        ln -sfn "$EIGEN_DIR" eigen3
    fi
fi

echo "ThirdParty done"; echo
