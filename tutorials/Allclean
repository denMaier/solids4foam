# Script
#     Allclean
#
# Description
#     Cleans tutorial directories by removing generated files,
#     log files, backup files, and other temporary artifacts.
#     Adapted from OpenFOAM tutorial cleaning utilities.
#
#------------------------------------------------------------------------------


echo "Cleaning backup files"
find . -type f \( -name "*~" -o -name "*.bak" \) -exec rm {} \;
find . \( -name 'core' -o -name 'core.[1-9]*' \) -exec rm {} \;
find . \( -name '*.pvs' -o -name '*.foam' \) -exec rm {} \;
rm logs > /dev/null 2>&1
rm testLoopReport > /dev/null 2>&1

echo ""

foamCleanTutorials -self

