FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      solidProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// thermalSolid only solves the heat equation, whereas thermalLinearGeometry
// solves the heat equation coupled with the momentum equation
//solidModel thermalSolid;
solidModel thermalLinearGeometry;

"thermalSolidCoeffs|thermalLinearGeometryCoeffs"
{
    // Maximum number of correctors
    nCorrectors             10000;

    // Solution tolerance
    solutionTolerance       1e-06;

    // Alternative solution tolerance
    alternativeTolerance    1e-07;

    // Write frequency for the residuals
    infoFrequency           100;
}

