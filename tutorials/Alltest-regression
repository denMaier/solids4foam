#!/usr/bin/env bash
set -Eeuo pipefail
IFS=$'\n\t'

# -------------------------------------------------------------------------
# solids4Foam regression test driver
#
# Copies regression test cases to a separate directory and
# runs them there to avoid polluting the original tutorials.
# -------------------------------------------------------------------------

echo "============================================================"
echo "solids4Foam regression tests"
echo "============================================================"

ROOT_DIR="$(pwd)"
REG_ROOT="${ROOT_DIR}/../tutorialsTest-regression"

# Create regression root directory
rm -rf "${REG_ROOT}"
mkdir -p "${REG_ROOT}"

# List of regression test directories (relative to tutorials/)
REGRESSION_TESTS=(
    "solids/elastoplasticity/perforatedPlate"
    "solids/hyperelasticity/rigidRotation/rotatingSphere"
    "solids/linearElasticity/plateHole"
    "solids/poroelasticity/rodAndSeabed"
    "solids/thermoelasticity/slabCooling"
    "solids/viscoelasticity/viscoTube"
    "fluidSolidInteraction/3dTube"
    "fluidSolidInteraction/beamInCrossFlow"
    "fluidSolidInteraction/flexibleDamBreak"
    "fluidSolidInteraction/perpendicularFlap"
)

failures=0

for testCase in "${REGRESSION_TESTS[@]}"; do
    echo
    echo "------------------------------------------------------------"
    echo "Running regression test: ${testCase}"
    echo "------------------------------------------------------------"

    SRC_CASE="${ROOT_DIR}/${testCase}"
    DST_CASE="${REG_ROOT}/${testCase}"

    # Copy test case (fresh copy each time)
    rm -rf "${DST_CASE}"
    mkdir -p "$(dirname "${DST_CASE}")"
    cp -a "${SRC_CASE}" "${DST_CASE}"

    cd "${DST_CASE}"

    if [[ ! -x ./regressionTest.sh ]]; then
        echo "FAIL: regressionTest.sh not found or not executable in ${testCase}"
        failures=$((failures + 1))
        continue
    fi

    if ! ./regressionTest.sh; then
        echo "FAIL: regression test failed in ${testCase}"
        failures=$((failures + 1))
    else
        echo "PASS: regression test passed in ${testCase}"
    fi
done

echo
echo "============================================================"

if (( failures > 0 )); then
    echo "Regression tests FAILED (${failures} failing case(s))"
    exit 1
else
    echo "All regression tests PASSED"
    exit 0
fi
