FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      solidProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solidModel     linearGeometryTotalDisplacement;
//solidModel     vertexCentredLinearGeometry;

"vertexCentredLinearGeometryCoeffs|linearGeometryTotalDisplacementCoeffs"
{
    // Solution algorithm (PETScSNES, implicitSegregated, explicit, ...)
    solutionAlgorithm PETScSNES;

    // Compact edge discretisation fraction
    // 0 -> more accurate but oscillations more likely
    // 1 -> less accurate but oscillations less likely
    //zeta           0.1;

    // PETSc options
    //optionsFile petscOptions.mumps;
    //optionsFile petscOptions.hypre;
    optionsFile petscOptions.mf.hypre;
}

