FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    system;
    object      sampleDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

setFormat raw;

surfaceFormat vtk;

interpolationScheme cellPointFace;

fields
(
    sigma:Transformed
);

sets
(
    line
    {
        type       face;
        axis       distance;
        start (0.0 0.0 0.0005);
        end   (0.07 0.07 0.0005);
    }
);

surfaces
();

